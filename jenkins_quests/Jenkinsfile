pipeline {
    agent any

    parameters {
        booleanParam(name: 'ROLLBACK_ONLY', defaultValue: false, description: 'Включить только откат на предыдущую версию')
    }

    environment {
        IMAGE_NAME = "report-service"
        PORT = "8081"
        CONTAINER_PORT = "5000"
        SUCCESS_FILE = "last_successful_build.txt"
    }

    stages {
        stage('Rollback Logic') {
            when { expression { params.ROLLBACK_ONLY } }
            steps {
                script {
                    echo "Режим ROLLBACK_ONLY активен. Выполняю откат..."
                    rollbackToPrevious()
                }
            }
        }

        stage('Test') {
            when { expression { !params.ROLLBACK_ONLY } }
            steps {
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                    pytest
                '''
            }
        }

        stage('Build') {
            when { expression { !params.ROLLBACK_ONLY } }
            steps {
                sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} ."
            }
        }

        stage('Deploy') {
            when { expression { !params.ROLLBACK_ONLY } }
            steps {
                script {
                    deployImage("${IMAGE_NAME}:${BUILD_NUMBER}")
                }
            }
        }

        stage('Health-check') {
            when { expression { !params.ROLLBACK_ONLY } }
            steps {
                script {
                    try {
                        // Ожидание запуска приложения (опционально)
                        sleep 5
                        sh "curl -f http://localhost:${PORT}/health"
                        
                        // Если успешно, сохраняем номер билда
                        sh "echo ${BUILD_NUMBER} > ${SUCCESS_FILE}"
                        echo "Health-check пройден успешно. Версия ${BUILD_NUMBER} сохранена."
                    } catch (Exception e) {
                        echo "Health-check провален! Начинаю автоматический откат..."
                        rollbackToPrevious()
                        error "Pipeline завершен с ошибкой из-за неудачного health-check"
                    }
                }
            }
        }
    }

    post {
        success {
            sh "curl http://localhost:${PORT}/health"
        }
    }
}

// Функции-помощники
def deployImage(imageTag) {
    sh """
        docker stop ${IMAGE_NAME} || true
        docker rm ${IMAGE_NAME} || true
        docker run -d -p ${PORT}:${CONTAINER_PORT} --name ${IMAGE_NAME} ${imageTag}
    """
}

def rollbackToPrevious() {
    if (fileExists(SUCCESS_FILE)) {
        def lastVersion = readFile(SUCCESS_FILE).trim()
        echo "Откат к версии: ${lastVersion}"
        deployImage("${IMAGE_NAME}:${lastVersion}")
    } else {
        error "Файл ${SUCCESS_FILE} не найден. Откат невозможен!"
    }
}
